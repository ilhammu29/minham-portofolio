DOMAIN=portfolio.example.com
ACME_EMAIL=you@example.com

# App admin login (JWT)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=PASTE_BCRYPT_HASH_HERE
ADMIN_JWT_SECRET=replace-with-very-long-random-secret
ADMIN_JWT_EXPIRES=12h

# Reverse-proxy protection for /admin
ADMIN_ALLOWED_IPS=103.10.10.10/32 127.0.0.1/32
ADMIN_BASIC_USER=opsadmin
ADMIN_BASIC_PASSWORD_HASH=PASTE_CADDY_BCRYPT_HASH_HERE

# Optional backup tuning
BACKUP_INTERVAL_MIN=360
BACKUP_KEEP_DAYS=14
